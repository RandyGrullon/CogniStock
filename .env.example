# ─── ENTORNO ───────────────────────────────────────────────
ENVIRONMENT=local

# ─── BASE DE DATOS (SQLITE O SUPABASE) ─────────────────────
DATABASE_URL=sqlite:///./stock_analyst.db
# Para usar Supabase, rellena estas dos:
SUPABASE_URL=
SUPABASE_KEY=

# ─── INTELIGENCIA ARTIFICIAL (GRATIS Y RÁPIDA) ────────────
# Consigue tu clave gratis en https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# Modelo Groq (consulta https://console.groq.com/docs/deprecations)
GROQ_MODEL=llama-3.1-8b-instant

# ─── DATOS DE MERCADO (OPCIONALES / GRATIS) ────────────────
# El sistema usa yfinance (gratis) por defecto para noticias y precios.
# Si quieres datos extra, puedes añadir estas pero no son obligatorias.
FINNHUB_API_KEY=
ALPHA_VANTAGE_KEY=

# ─── CONFIGURACIÓN DEL PORTAFOLIO ──────────────────────────
CAPITAL_INICIAL=100000
TICKERS_MONITOREADOS=TSLA,NVDA,AAPL,MSFT,META,AMZN,AMD,GOOGL
CONFIANZA_MINIMA_PARA_TRADE=70

# ─── SEGURIDAD ─────────────────────────────────────────────
API_SECRET_KEY=generate-a-safe-random-key
