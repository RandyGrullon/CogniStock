# ─── HOSTING ───────────────────────────────────────────────
# Toda la lógica corre en Next.js API Routes en Vercel.
# Configura estas vars en el dashboard de Vercel (Project Settings -> Environment Variables).

# ─── SUPABASE ──────────────────────────────────────────────
# La instancia única de base de datos del sistema.
SUPABASE_URL=
# Clave service-role (uso solo en server / API Routes / Cron). NUNCA exponer en el navegador.
SUPABASE_SERVICE_KEY=
# Clave anon (opcional, si en algún momento usamos Supabase desde el browser con RLS).
SUPABASE_ANON_KEY=

# ─── INTELIGENCIA ARTIFICIAL (GROQ) ────────────────────────
# Consigue tu clave gratis en https://console.groq.com/
GROQ_API_KEY=
# Modelo Groq (consulta https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── CONFIGURACIÓN DEL PORTAFOLIO ──────────────────────────
CAPITAL_INICIAL=100000
TICKERS_MONITOREADOS=TSLA,NVDA,AAPL,MSFT,META,AMZN,AMD,GOOGL
CONFIANZA_MINIMA_PARA_TRADE=70

# ─── VERCEL CRON ───────────────────────────────────────────
# Vercel envía este header en sus invocaciones programadas.
# Define un valor seguro y configúralo igual en Project Settings.
CRON_SECRET=cambia-esto-por-un-string-largo-y-aleatorio
# En desarrollo local puedes hacer bypass del check:
# ALLOW_INSECURE_CRON=1

# ─── DATOS DE MERCADO ──────────────────────────────────────
# Las API Routes usan TradingView WS (sin API key) + Yahoo Finance (sin API key)
# como fallback. Las siguientes son opcionales para mejorar el contexto:
FINNHUB_API_KEY=
ALPHA_VANTAGE_KEY=
